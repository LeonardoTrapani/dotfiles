{
  "permissions": {
    "ask": [
      "Bash(git push:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); /usr/bin/starship prompt --logical-dir=\"$cwd\" --status=0"
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--browser",
        "chromium",
        "--headless"
      ]
    }
  },
  "enabledPlugins": {
    "dev-browser@dev-browser-marketplace": true
  }
}
