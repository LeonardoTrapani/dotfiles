#!/bin/bash
# Ralph Wiggum - Long-running AI agent loop
# Usage: ralph <iterations> [-d] [-cc]

set -e

iterations=""
use_docker=false
use_claude=false

# opencode defaults to codex-ish models; force non-codex
opencode_model="openai/gpt-5.2"

# parse args
for arg in "$@"; do
  if [[ "$arg" == "-d" ]]; then
    use_docker=true
  elif [[ "$arg" == "-cc" ]]; then
    use_claude=true
  elif [[ -z "$iterations" ]]; then
    iterations="$arg"
  fi
done

if [[ -z "$iterations" ]]; then
  echo "Usage: ralph <iterations> [-d] [-cc]"
  echo "  -d: run in docker sandbox"
  echo "  -cc: use claude code instead of opencode"
  exit 1
fi

# ralph data directory (stowed from dotfiles/ralph/ralph/)
RALPH_DIR="${RALPH_DIR:-$HOME/ralph}"
PROGRESS_FILE="progress.txt"
PROMPT_FILE="$RALPH_DIR/prompt.md"

mkdir -p "$RALPH_DIR"

# initialize progress file if it doesn't exist
if [ ! -f "$PROGRESS_FILE" ]; then
  echo "# Ralph Progress Log" > "$PROGRESS_FILE"
  echo "Started: $(date)" >> "$PROGRESS_FILE"
  echo "---" >> "$PROGRESS_FILE"
fi

if [ ! -f "$PROMPT_FILE" ]; then
  echo "Missing prompt file: $PROMPT_FILE"
  echo "Create it (e.g. copy from dotfiles ralph prompt.md)"
  exit 1
fi

prompt=$(cat "$PROMPT_FILE")


# set up commands based on flags
if $use_claude; then
  cmd_single="claude --dangerously-skip-permissions"
  cmd_multi="claude -p --dangerously-skip-permissions"
else
  cmd_single="opencode"
  export OPENCODE_PERMISSION='{"*":"allow"}'
  cmd_multi="opencode run -m $opencode_model"
fi
$use_docker && cmd_single="docker sandbox run $cmd_single"
$use_docker && cmd_multi="docker sandbox run $cmd_multi"

echo "Starting Ralph - Max iterations: $iterations"
$use_claude && echo "Using: Claude Code" || echo "Using: OpenCode"

# single iteration mode
if [[ "$iterations" == "1" ]]; then
  if $use_claude; then
    eval "$cmd_single \"\$prompt\""
  else
    echo "$prompt" | wl-copy
    echo "Prompt copied to clipboard"
    eval "$cmd_single"
  fi
  exit 0
fi

# multi iteration loop
for ((i=1; i<=iterations; i++)); do
  echo ""
  echo "═══════════════════════════════════════════════════════"
  echo "  Ralph iteration $i of $iterations"
  echo "═══════════════════════════════════════════════════════"

  if $use_claude; then
    result=$(echo "$prompt" | eval "$cmd_multi")
  else
    result=$(eval "$cmd_multi \"\$prompt\"")
  fi
  echo "$result"

  if [[ "$result" == *"<promise>COMPLETE</promise>"* ]]; then
    echo ""
    echo "Ralph completed all tasks!"
    echo "Completed at iteration $i of $iterations"
    exit 0
  fi

  echo "Iteration $i complete. Continuing..."
  sleep 2
done

echo ""
echo "Ralph reached max iterations ($iterations) without completing."
echo "Check progress.txt for status."
exit 1
